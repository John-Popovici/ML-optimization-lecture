      "source": [
        "\n",
        "$$\\begin{align*}\n",
        "    L(x,y) &= x^2 + 1000\\cdot y^2\\\\[5pt]\n",
        "    \\nabla_L(x,y) &= \n",
        "    \\begin{pmatrix}\n",
        "        2x\\\\\n",
        "        2000y\n",
        "    \\end{pmatrix}\n",
        "\\end{align*}$$"
      ]
    },
