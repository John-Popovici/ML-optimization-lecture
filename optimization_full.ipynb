        "# We see here that learning rate is adapted to x[1], so x[0] goes towards the \n",
        "# minimum very slowly, while x[1] gets there really fast\n",
        "positions1, losses1 = gradient_descent(0.0007, \n",
        "                                     num_iterations=20, \n",
